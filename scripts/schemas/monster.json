{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tavern.local/schemas/monster.json",
  "title": "Monster",
  "description": "SRD 5.2.1 monster stat block",
  "type": "object",
  "required": [
    "name", "size", "type", "alignment",
    "ac", "hp", "hp_formula", "speed", "ability_scores",
    "damage_resistances", "damage_immunities", "damage_vulnerabilities",
    "condition_immunities", "senses", "cr", "xp",
    "traits", "actions"
  ],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "size": {
      "type": "string",
      "enum": ["tiny", "small", "medium", "large", "huge", "gargantuan"]
    },
    "type": {
      "type": "string",
      "description": "Creature type (e.g. 'beast', 'humanoid', 'undead', 'fiend')"
    },
    "alignment": {
      "type": "string",
      "description": "Alignment string (e.g. 'neutral evil', 'any alignment', 'unaligned')"
    },
    "ac": {
      "type": "integer",
      "minimum": 0
    },
    "ac_type": {
      "type": "string",
      "description": "AC source description (e.g. 'natural armor', 'chain mail')"
    },
    "hp": {
      "type": "integer",
      "minimum": 0
    },
    "hp_formula": {
      "type": "string",
      "description": "HP formula (e.g. '5d8+15')"
    },
    "speed": {
      "type": "object",
      "required": ["walk"],
      "additionalProperties": false,
      "properties": {
        "walk": { "type": "integer", "minimum": 0 },
        "swim": { "type": "integer", "minimum": 0 },
        "fly": { "type": "integer", "minimum": 0 },
        "burrow": { "type": "integer", "minimum": 0 },
        "climb": { "type": "integer", "minimum": 0 },
        "hover": { "type": "boolean", "default": false }
      }
    },
    "ability_scores": {
      "type": "object",
      "required": ["STR", "DEX", "CON", "INT", "WIS", "CHA"],
      "additionalProperties": false,
      "properties": {
        "STR": { "type": "integer", "minimum": 1 },
        "DEX": { "type": "integer", "minimum": 1 },
        "CON": { "type": "integer", "minimum": 1 },
        "INT": { "type": "integer", "minimum": 1 },
        "WIS": { "type": "integer", "minimum": 1 },
        "CHA": { "type": "integer", "minimum": 1 }
      }
    },
    "saving_throws": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "STR": { "type": "integer" },
        "DEX": { "type": "integer" },
        "CON": { "type": "integer" },
        "INT": { "type": "integer" },
        "WIS": { "type": "integer" },
        "CHA": { "type": "integer" }
      }
    },
    "skills": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "acrobatics", "animal_handling", "arcana", "athletics",
          "deception", "history", "insight", "intimidation", "investigation",
          "medicine", "nature", "perception", "performance", "persuasion",
          "religion", "sleight_of_hand", "stealth", "survival"
        ]
      },
      "additionalProperties": { "type": "integer" }
    },
    "damage_resistances": {
      "type": "array",
      "items": { "$ref": "#/$defs/damage_type" }
    },
    "damage_immunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/damage_type" }
    },
    "damage_vulnerabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/damage_type" }
    },
    "condition_immunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "senses": {
      "type": "object",
      "required": ["passive_perception"],
      "additionalProperties": false,
      "properties": {
        "darkvision": { "type": "integer", "minimum": 0 },
        "blindsight": { "type": "integer", "minimum": 0 },
        "tremorsense": { "type": "integer", "minimum": 0 },
        "truesight": { "type": "integer", "minimum": 0 },
        "passive_perception": { "type": "integer", "minimum": 0 }
      }
    },
    "languages": {
      "type": "string",
      "description": "Languages as a descriptive string (e.g. 'Common, Goblin')"
    },
    "cr": {
      "type": "number",
      "minimum": 0,
      "description": "Challenge rating (e.g. 0.125, 0.25, 0.5, 1, 2, ... 30)"
    },
    "xp": {
      "type": "integer",
      "minimum": 0
    },
    "traits": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "bonus_actions": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "reactions": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "legendary_actions": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "lair_actions": {
      "type": "array",
      "items": { "$ref": "monster_action.json" }
    },
    "description": {
      "type": "string"
    }
  },
  "$defs": {
    "damage_type": {
      "type": "string",
      "enum": [
        "acid", "bludgeoning", "cold", "fire", "force",
        "lightning", "necrotic", "piercing", "poison",
        "psychic", "radiant", "slashing", "thunder"
      ]
    },
    "condition": {
      "type": "string",
      "enum": [
        "blinded", "charmed", "deafened", "exhaustion", "frightened",
        "grappled", "incapacitated", "invisible", "paralyzed", "petrified",
        "poisoned", "prone", "restrained", "stunned", "unconscious"
      ]
    }
  }
}
